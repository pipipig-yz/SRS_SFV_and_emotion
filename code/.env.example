# Server
PORT=3000

# Data backend. Current supported value: mock
DATA_BACKEND=mock

# Reserved for the PostgreSQL migration phase
DATABASE_URL=

# DeepSeek chat proxy
DEEPSEEK_API_KEY=

# Volcengine Doubao ASR. Keep the real key only in local .env.
VOLC_ASR_API_KEY=
VOLC_ASR_UID=srs-chatbot
VOLC_ASR_FLASH_RESOURCE_ID=volc.bigasr.auc_turbo
VOLC_ASR_RESOURCE_ID=volc.seedasr.auc
